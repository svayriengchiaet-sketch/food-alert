# Claude API (必須)
# https://console.anthropic.com からAPIキーを取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Upstash Redis (必須: Vercelデプロイ時)
# Vercel > Storage > Connect Store > Upstash Redis から取得
# または https://upstash.com から直接作成
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Resend (メール通知 - 任意)
# https://resend.com からAPIキーを取得（無料プランあり）
RESEND_API_KEY=re_your_resend_api_key_here

# Cronジョブ保護 (任意: Vercelデプロイ時に設定推奨)
# 任意のランダム文字列を設定
CRON_SECRET=your_random_secret_here
